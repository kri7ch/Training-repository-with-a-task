<Page x:Class="ShoeStore.Pages.OrderConfirmationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Оформление заказа"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <Grid>
                <Button x:Name="BackButton" Background="#7FFF00" Content="Назад" HorizontalAlignment="Left" Padding="10,2" Click="BackButton_Click"/>
                <Button x:Name="AddProductToOrderButton" Background="#00FA9A" Content="Добавить товары в заказ" HorizontalAlignment="Right" Padding="10,2" Click="AddProductToOrderButton_Click"
                        Visibility="Collapsed"/>
            </Grid>
            <TextBlock Text="Оформление заказа" FontSize="20" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <ListView x:Name="BasketList" Grid.Row="1" Margin="10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" FontSize="10" TextWrapping="Wrap" MaxWidth="400"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                             <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N2} руб.}" Margin="0,0,10,0"/>
                             <Button Content="Удалить" Click="DeleteFromBasket_Click" Tag="{Binding Id}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Margin="10">
            <TextBlock Text="Пользователь (для кого заказ):" x:Name="UserLabel"/>
            <ComboBox x:Name="UserCombo" Margin="0,5,0,10" DisplayMemberPath="FullName" SelectedValuePath="Id"/>

            <TextBlock Text="Пункт выдачи:"/>
            <ComboBox x:Name="PickupPointCombo" Margin="0,5,0,0" DisplayMemberPath="FullAddress"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Общая стоимость: " FontWeight="Bold"/>
                <TextBlock x:Name="TotalCostText" Text="0.00 руб."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Общая скидка: " FontWeight="Bold"/>
                <TextBlock x:Name="TotalDiscountText" Text="0.00 руб."/>
            </StackPanel>
        </StackPanel>

        <Button x:Name="OrderButton" Grid.Row="3" Background="#00FA9A" Content="Заказать" Margin="10" Padding="20,10" HorizontalAlignment="Center" Click="OrderButton_Click"/>
    </Grid>
</Page>
