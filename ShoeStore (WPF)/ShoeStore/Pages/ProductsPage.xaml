<Page x:Class="ShoeStore.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Товары">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
            <Border x:Name="OrderModeHeader" Background="#FFF9C4" BorderBrush="#FBC02D" BorderThickness="1" Padding="10" Margin="0,0,0,10"
                    Visibility="{Binding IsOrderMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="OrderModeText" Text="Оформление заказа для пользователя: " FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TargetUserNameText" Text="{Binding TargetUserName}" FontWeight="Bold" Foreground="DarkRed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddProductButton" Content="Добавить товар" Margin="0,0,10,0" Padding="10,2" Background="#00FA9A"
                        Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.ShowCatalogAddButton, Converter={StaticResource BooleanToVisibilityConverter}}" 
                        Click="AddProductButton_Click"/>

                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="200" TextChanged="SearchBox_TextChanged"/>
                
                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <ComboBox x:Name="SortCombo" Width="150" SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="Без сортировки"/>
                    <ComboBoxItem Content="Цена (по возрастанию)"/>
                    <ComboBoxItem Content="Цена (по убыванию)"/>
                </ComboBox>

                <TextBlock Text="Фильтрация:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <ComboBox x:Name="FilterCombo" Width="150" SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="Все диапазоны"/>
                    <ComboBoxItem Content="0 - 9.99%"/>
                    <ComboBoxItem Content="10 - 14.99%"/>
                    <ComboBoxItem Content="15% и более"/>
                </ComboBox>
                
                <Button x:Name="OrdersButton" Content="Заказы" Margin="20,0,0,0" Padding="10,2" Visibility="Collapsed" Click="OrdersButton_Click"/>
                <Button x:Name="BasketButton" Content="Корзина" Margin="10,0,0,0" Padding="10,2" Visibility="Collapsed" Click="BasketButton_Click"/>
            </StackPanel>
        </StackPanel>

        <ListView x:Name="ProductsList" Grid.Row="2" Margin="10" HorizontalContentAlignment="Stretch">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить к заказу" Click="AddToOrder_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBigDiscount}" Value="True">
                            <Setter Property="Background" Value="#2E8B57"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StockCount}" Value="0">
                            <Setter Property="Background" Value="#ADD8E6"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="0">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border BorderBrush="Black" BorderThickness="1" Grid.Column="0" Margin="5" Width="150" Height="150" VerticalAlignment="Top">
                                <Image Source="{Binding PhotoUri}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,5,10,5" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CategoryAndName}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                                    <Button Content="Редактировать" Margin="10,0,0,0" Padding="5,0" 
                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.IsAdminOrManager, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="EditProductButton_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                                
                                <TextBlock Text="Описание товара:" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                
                                <TextBlock Text="Производитель:" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding ManufacturerName}"/>
                                
                                <TextBlock Text="Поставщик:" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding SupplierName}"/>
                                
                                <TextBlock Text="Цена:" Margin="0,5,0,0"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}" Foreground="Red" TextDecorations="Strikethrough" Margin="0,0,10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDiscounted}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N2}}" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <TextBlock Text="Единица измерения:" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding Unit}"/>
                                
                                <TextBlock Text="Количество на складе:" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding StockCount}"/>
                            </StackPanel>

                            <Grid Grid.Column="2" Width="120" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Content="В заказ" Margin="0,10,0,0" Padding="10,5"
                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.IsOrderMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="DirectAddToOrder_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="RecordsCountText" Grid.Row="3" Margin="10" HorizontalAlignment="Right" Text="0 из 0"/>
    </Grid>
</Page>
